# Service
APP_ENV=development
LOG_LEVEL=INFO
PORT=8080

# =============================================================================
# 阿里云百炼（DashScope，OpenAI 兼容）— 推荐
# 控制台：https://bailian.console.aliyun.com/  — 创建 API-KEY 后填入 ONLINE_MODEL_API_KEY
# =============================================================================
# BASE_URL（只需保留一行）— 百炼 OpenAI 兼容：
# 部分账号/文档使用 coding 域名：
ONLINE_MODEL_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# 北京兼容模式：
# ONLINE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 新加坡：
# ONLINE_MODEL_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 美国（弗吉尼亚）：
# ONLINE_MODEL_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# 模型名称以控制台「OpenAI 兼容」文档为准，例如：
ONLINE_MODEL_NAME=qwen-plus
ONLINE_MODEL_API_KEY=replace-with-your-dashscope-api-key

# 使用百炼时请设为 online_first 或 quality_first（二者在「仅配置线上」时都会走 ONLINE_*）
MODEL_ROUTING_POLICY=online_first

# Optional aliases (if ONLINE_* are empty, these are used instead)
# OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# OPENAI_API_KEY=your-key
# OPENAI_MODEL=qwen-plus

# Local model (optional fallback / local dev)
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1
LOCAL_MODEL_API_KEY=local-not-required

# Note: put `.env` in the repository root (next to docker-compose.yml).
# Load order: repo root -> service/ -> current working directory.
