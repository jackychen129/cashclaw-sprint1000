# Service
APP_ENV=development
LOG_LEVEL=INFO
PORT=8080

# Local model endpoint (OpenAI-compatible proxy or Ollama bridge)
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1
LOCAL_MODEL_API_KEY=local-not-required

# Online model endpoint (OpenAI-compatible)
# OpenAI:
ONLINE_MODEL_BASE_URL=https://api.openai.com/v1
ONLINE_MODEL_NAME=gpt-4o-mini
ONLINE_MODEL_API_KEY=replace-me

# Alibaba DashScope (OpenAI-compatible mode) — uncomment and set:
# ONLINE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ONLINE_MODEL_NAME=qwen-plus
# ONLINE_MODEL_API_KEY=your-dashscope-api-key

# Optional aliases (many SDKs use these names — we read them if ONLINE_* is empty):
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=your-key
# OPENAI_MODEL=qwen-plus

# Routing policy: local_first | online_first | quality_first
MODEL_ROUTING_POLICY=quality_first

# Note: put .env in the repository root (same folder as docker-compose.yml), not only inside service/.
# The app loads .env from: repo root -> service/ -> current working directory.
