# Service
APP_ENV=development
LOG_LEVEL=INFO
PORT=8080

# =============================================================================
# 阿里云百炼 Coding Plan（OpenAI 兼容）— 推荐编程套餐接入
# 控制台与说明：https://www.alibabacloud.com/help/zh/model-studio/coding-plan-overview
# API Key：Coding Plan 专属 sk-sp-xxxx（与按量 sk- 及 Base URL 均不互通）
# 推荐模型含：glm-5、qwen3.5-plus、kimi-k2.5 等，以套餐页为准
# =============================================================================
# 国内 coding 域名（常用）：
ONLINE_MODEL_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# 国际：
# ONLINE_MODEL_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

ONLINE_MODEL_NAME=glm-5
ONLINE_MODEL_API_KEY=replace-with-your-coding-plan-sk-sp-key

MODEL_ROUTING_POLICY=online_first

# =============================================================================
# 或：智谱官网 GLM（非百炼）
# =============================================================================
# ONLINE_MODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ONLINE_MODEL_NAME=glm-4.7
# ONLINE_MODEL_API_KEY=replace-with-your-zhipu-api-key

# =============================================================================
# 或：百炼按量 DashScope 通用兼容模式（非 Coding Plan）
# =============================================================================
# ONLINE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ONLINE_MODEL_NAME=qwen-plus
# ONLINE_MODEL_API_KEY=replace-with-your-dashscope-api-key

# Optional aliases (if ONLINE_* are empty)
# OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# OPENAI_API_KEY=your-key
# OPENAI_MODEL=glm-5

# Local model (optional fallback)
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1
LOCAL_MODEL_API_KEY=local-not-required

# Put `.env` in the repository root (next to docker-compose.yml).
